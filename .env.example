# Supabase 配置
# 从 Supabase 项目设置中获取这些值
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# 
# 当前项目 URL: https://saeplsevqechdnlkwjyz.supabase.co
# 请在 Supabase Dashboard > Settings > API 中获取 anon key
# 
# 注意：
# - 复制 .env.example 为 .env.local 并填入实际的 ANON_KEY
# - VITE_ 前缀是必需的，这样 Vite 才能将环境变量注入到客户端代码中
# - 如果不配置这些变量，应用将降级使用 SQLite 本地存储

VITE_SUPABASE_URL=https://saeplsevqechdnlkwjyz.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
