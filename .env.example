# 部署平台配置
# 不同平台需要不同的 base 路径配置：
# - GitHub Pages (julius19910613.github.io/player-grouping/): VITE_BASE_URL=/player-grouping/
# - Vercel (player-grouping.vercel.app/): 不需要设置（默认 /）
# - Cloudflare Pages: 不需要设置（默认 /）
# - 本地开发: 不需要设置（默认 /）
#
# 注意：
# - 本地开发时不需要设置此变量
# - GitHub Pages 部署会在 GitHub Actions 中自动设置
# - Vercel 部署需要在项目设置中配置环境变量
VITE_BASE_URL=

# Supabase 配置
# 从 Supabase 项目设置中获取这些值
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# 
# 当前项目 URL: https://saeplsevqechdnlkwjyz.supabase.co
# 请在 Supabase Dashboard > Settings > API 中获取 anon key
# 
# 注意：
# - 复制 .env.example 为 .env.local 并填入实际的 ANON_KEY
# - VITE_ 前缀是必需的，这样 Vite 才能将环境变量注入到客户端代码中
# - 如果不配置这些变量，应用将降级使用 SQLite 本地存储

VITE_SUPABASE_URL=https://saeplsevqechdnlkwjyz.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI 服务配置（豆包/火山引擎 ARK）
# 用于智能能力评分建议和分组优化
# 如果不配置，将降级使用基于规则的传统算法
# 
# 获取方式：
# 1. 注册火山引擎账号
# 2. 开通豆包大模型服务
# 3. 创建推理接入点获取 endpoint
# 4. 获取 API Key
VITE_ARK_API_KEY=your-ark-api-key-here
VITE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
