# 部署平台配置
# 不同平台需要不同的 base 路径配置：
# - GitHub Pages (julius19910613.github.io/player-grouping/): VITE_BASE_URL=/player-grouping/
# - Vercel (your-project.vercel.app/): VITE_BASE_URL=/
# - Cloudflare Pages: 不需要设置（默认 /）
# - 本地开发: 不需要设置（默认 /）
#
# 注意：
# - 本地开发时不需要设置此变量
# - GitHub Pages 部署会在 GitHub Actions 中自动设置
# - Vercel 部署：必须在 Vercel 项目设置中配置（见 docs/DEPLOYMENT.md）
#
VITE_BASE_URL=

# ============================================
# 客户端环境变量 (VITE_ 前缀)
# ============================================
#
# Supabase 配置（客户端）
# 从 Supabase 项目设置中获取这些值
#
# 获取方式：
# 1. 访问 Supabase Dashboard
# 2. 选择你的项目
# 3. 进入 Settings → API
# 4. 复制 Project URL 和 anon public key
#
# 部署环境配置：
# - 本地开发：在 .env.local 中设置（此文件）
# - Vercel：在 Vercel 项目设置 → Environment Variables 中添加
# - GitHub Pages：在 Repository Settings → Secrets and variables → Actions 中添加
#
# 重要：
# - 变量名必须以 VITE_ 开头（Vite 要求）
# - 添加或修改环境变量后需要重新部署
# - 如果不配置这些变量，应用将降级使用 SQLite 本地存储
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI 服务配置（豆包/火山引擎 ARK）
# 用于智能能力评分建议和分组优化
# 如果不配置，将降级使用基于规则的传统算法
#
# 获取方式：
# 1. 注册火山引擎账号
# 2. 开通豆包大模型服务
# 3. 创建推理接入点获取 endpoint
# 4. 获取 API Key
#
VITE_ARK_API_KEY=your-ark-api-key-here
VITE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Brave Search API 配置（联网搜索功能）
# 用于智能助手联网搜索最新篮球信息
# 如果不配置，联网搜索功能将不可用
#
# 获取方式：
# 1. 访问 https://brave.com/search/api/
# 2. 注册并创建 API Key
# 3. 选择免费计划（2000 次/月）
#
# 注意：
# - 变量名必须以 VITE_ 开头（Vite 要求）
#
VITE_BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Gemini API Key（客户端可选）
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# 服务端环境变量 (Vercel Serverless Functions)
# ============================================
# 以下变量用于 Vercel serverless functions (api/ 目录)
# 这些变量不需要 VITE_ 前缀
#
# MCP 配置
# 默认启用 MCP Server。设为 false 可禁用 MCP，使用 fallback 模式（直接使用 Supabase client）
# 本地开发建议设为 false，避免需要 SUPABASE_ACCESS_TOKEN
ENABLE_MCP=true

# Supabase Project ID (用于 MCP Server 连接)
# 获取方式：从 Supabase 项目 URL 中提取
# 例如：https://saeplsevqechdnlkwjyz.supabase.co 的 project ID 是 saeplsevqechdnlkwjyz
# 注意：只有在 ENABLE_MCP=true 时才需要此变量
SUPABASE_PROJECT_ID=your-project-id-here

# Supabase Access Token (用于 MCP Server，可选)
# 获取方式：Supabase Dashboard → Account → Access Tokens → Generate New Token
# 注意：只有在 ENABLE_MCP=true 时才需要此变量
SUPABASE_ACCESS_TOKEN=your-access-token-here

# Supabase URL and ANON KEY (服务端备用)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API Key (用于 Chat API)
# 获取方式：https://ai.studio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Brave Search API Key (服务端备用)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# ============================================
# SQL Query Agent A/B 测试配置
# ============================================
# 是否使用增强版的 SQL Query Agent
# 设为 true 使用新版本，设为 false 使用旧版本
# 用于对比测试和性能优化
#
# 重要：首次运行 A/B 测试前，必须确保：
# 1. 配置 VITE_SUPABASE_URL 和 VITE_SUPABASE_ANON_KEY（或服务端变量）
# 2. 配置 GEMINI_API_KEY（用于 Enhanced 版本的查询解析）
# 3. 构建项目：npm run build
USE_ENHANCED_SQL_AGENT=false
